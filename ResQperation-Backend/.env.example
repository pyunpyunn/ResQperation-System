APP_NAME=ResQperation
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Choose: sqlite, mysql, mariadb, pgsql, sqlsrv
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=resqperation
DB_USERNAME=root
DB_PASSWORD=
MYSQL_ATTR_SSL_CA=

# ============================================================================
# SESSION & CACHE
# ============================================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ============================================================================
# QUEUE CONFIGURATION
# ============================================================================
# Options: sync, database, redis, sqs, beanstalkd
# For production at scale: use redis
# For development/small scale: use database (current)
QUEUE_CONNECTION=database
DB_QUEUE_CONNECTION=
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=90

CACHE_STORE=database
# CACHE_PREFIX=cache_

MEMCACHED_HOST=127.0.0.1

# ============================================================================
# REDIS CONFIGURATION (Optional, for scaling)
# ============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_CACHE_DB=1

# ============================================================================
# MAIL CONFIGURATION
# ============================================================================
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@resqperation.com
MAIL_FROM_NAME=ResQperation

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_VERSION=v1
API_PREFIX=api
API_PAGINATION_PER_PAGE=15
API_PAGINATION_MAX_PER_PAGE=100
API_RESPONSE_FORMAT=json

# Rate limiting: max requests per period (in minutes)
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS=60
API_RATE_LIMIT_PERIOD=1

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins for mobile/web apps
# Examples: http://localhost:3000,http://localhost:5173,https://app.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# ============================================================================
# SANCTUM CONFIGURATION (API Authentication)
# ============================================================================
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
SANCTUM_GUARD=web

# ============================================================================
# AWS CONFIGURATION (Optional, for S3 storage or SQS queue)
# ============================================================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=

# ============================================================================
# SENTRY CONFIGURATION (Optional, for error tracking)
# ============================================================================
# SENTRY_DSN=
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
